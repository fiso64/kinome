{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "src/shared/*"
      ],
      "@lib/*": [
        "src/renderer/src/lib/*"
      ],
      "@components/*": [
        "src/renderer/src/components/*"
      ],
      "@ui/*": [
        "src/renderer/src/components/ui/*"
      ],
      "@modals/*": [
        "src/renderer/src/components/modals/*"
      ],
      "@renderer/*": [
        "src/renderer/src/*"
      ]
    }
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.node.json"
    },
    {
      "path": "./tsconfig.web.json"
    }
  ]
}