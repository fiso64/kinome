{
  "name": "media-browser",
  "version": "1.0.0",
  "description": "A media server and manager",
  "main": "src/main/server.ts",
  "author": "example.com",
  "homepage": "https://github.com/example/media-browser",
  "scripts": {
    "format": "prettier --plugin prettier-plugin-svelte --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "svelte-check": "svelte-check --tsconfig ./tsconfig.web.json",
    "typecheck": "bun run typecheck:node",
    "dev:backend": "PORT=3001 bun --watch src/main/server.ts",
    "dev:frontend": "vite",
    "dev": "concurrently --raw \"bun run dev:backend\" \"bun run dev:frontend\"",
    "pretty": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json,svelte}\"",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "start": "NODE_ENV=production bun src/main/server.ts",
    "prod": "bun run build; bun run start",
    "publish:linux-arm": "bun scripts/publish.ts --target=linux-arm64",
    "publish:linux-x64": "bun scripts/publish.ts --target=linux-x64",
    "publish:win": "bun scripts/publish.ts --target=windows-x64"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "@tanstack/svelte-query": "^6.0.18",
    "bcryptjs": "^3.0.3",
    "elysia": "^1.4.22",
    "fast-deep-equal": "^3.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.8",
    "@types/cors": "^2.8.19",
    "@types/node": "^22.14.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.24.0",
    "eslint-plugin-svelte": "^3.5.1",
    "fuse.js": "^7.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte": "^5.26.1",
    "svelte-check": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^6.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}