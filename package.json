{
  "name": "media-browser",
  "version": "1.0.0",
  "description": "A media server and manager",
  "main": "src/main/server.ts",
  "author": "example.com",
  "homepage": "https://github.com/example/media-browser",
  "scripts": {
    "format": "prettier --plugin prettier-plugin-svelte --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "svelte-check": "svelte-check --tsconfig ./tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run svelte-check",
    "dev": "tsx src/main/server.ts",
    "pretty": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json,svelte}\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production tsx src/main/server.ts",
    "prod": "pnpm run build && pnpm run start"
  },
  "dependencies": {
    "@tanstack/svelte-query": "^6.0.18",
    "@types/compression": "^1.8.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fast-deep-equal": "^3.1.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.24.0",
    "eslint-plugin-svelte": "^3.5.1",
    "fuse.js": "^7.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte": "^5.26.1",
    "svelte-check": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}